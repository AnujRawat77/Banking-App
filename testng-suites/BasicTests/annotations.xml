<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CoreAnnotations">

    <listeners>
        <listener class-name="com.project.BankingApp.basictests.ApiTests.annotations.AnnotationListener"/>
        <listener class-name="com.project.BankingApp.basictests.ApiTests.annotations.AnnotationRetryListener"/>
    </listeners>

    <test name="CoreAnnotationTests">
        <classes>
            <class name="com.project.BankingApp.basictests.ApiTests.annotations.A1"/>
            <class name="com.project.BankingApp.basictests.ApiTests.annotations.A2"/>
        </classes>
    </test>

    <test name="FactoryAnnotationTests">
        <classes>
            <class name="com.project.BankingApp.basictests.ApiTests.annotations.LoginFactory"/>
        </classes>
    </test>

    <test name="GroupsTests">

        <groups>
            <run>
                <include name="Add"/>
                <include name="Divide"/>
                <include name="Regression"/>
            </run>
        </groups>

        <classes>
            <class name="com.project.BankingApp.basictests.ApiTests.annotations.GroupsTest"/>
        </classes>
    </test>

</suite>